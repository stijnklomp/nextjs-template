{
	"name": "nextjs-template",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "rm -rf .next ; NODE_ENV=production next build",
		"dev": "rm -f .next/dev/lock ; next dev",
		"doc": "typedoc",
		"format": "prettier --write .",
		"lint": "eslint --report-unused-disable-directives . --cache",
		"lint:fix": "eslint --report-unused-disable-directives . --cache --fix",
		"prepare": "husky",
		"sort": "./node_modules/stijnklomp-linting-formatting-config/sortJson.sh ./tsconfig.json ./.lintstagedrc.json",
		"start": "next start",
		"test": "jest",
		"test:acceptance": "jest test/acceptance",
		"test:coverage": "jest --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:feature": "jest test/feature",
		"test:unit": "jest --testPathPatterns='src/.*\\.(test|spec)\\.[jt]sx?$'",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@mantine/core": "^9.3.0",
		"@mantine/hooks": "^9.3.0",
		"@mantine/notifications": "^9.3.0",
		"@mantine/nprogress": "^9.3.0",
		"@tabler/icons-react": "^3.44.0",
		"motion": "^12.40.0",
		"next": "16.2.7",
		"next-intl": "^4.13.0",
		"react": "19.2.4",
		"react-dom": "19.2.4"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.9.1",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"eslint": "^10.4.1",
		"eslint-config-next": "^16.2.7",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-jest": "^29.15.2",
		"eslint-plugin-jsonc": "^3.2.0",
		"eslint-plugin-markdown": "^5.1.0",
		"eslint-plugin-package-json": "^1.3.0",
		"eslint-plugin-prettier": "^5.5.6",
		"eslint-plugin-yml": "^3.4.0",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"jest": "^30.4.2",
		"jest-environment-jsdom": "^30.4.1",
		"json-sort-cli": "^4.1.3",
		"lint-staged": "^17.0.7",
		"postcss": "^8.5.15",
		"postcss-preset-mantine": "^1.18.0",
		"postcss-simple-vars": "^7.0.1",
		"prettier": "^3.8.3",
		"prettier-plugin-packagejson": "^3.0.2",
		"sass": "^1.100.0",
		"stijnklomp-linting-formatting-config": "^7.1.0",
		"typedoc": "^0.28.19",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.60.1"
	},
	"engines": {
		"bun": ">=1.3.8"
	}
}
